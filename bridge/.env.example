# Gubbins bridge — example environment file.
#
# Copy to `.env` (which is git-ignored) and fill in real values locally. NEVER commit
# a real token or a real snapshot path. Placeholders only in this file.
#
# These are consumed from Phase HA-3 onward (the HTTP server); HA-1 only uses the
# snapshot path argument passed to the CLI. Listed now so the config surface is clear.
#
# The MCP stdio server (`node mcp.mjs`) uses ONLY GUBBINS_SNAPSHOT_PATH — stdio carries no
# network bearer token, so the token/host/port/rate-limit settings below do not apply to it.

# Absolute path to the synced gubbins-sync.json the PWA writes (NAS / synced drive).
GUBBINS_SNAPSHOT_PATH=/path/to/your/synced/gubbins-sync.json

# Shared bearer token Home Assistant must send. Generate your own; do not reuse this.
GUBBINS_BRIDGE_TOKEN=replace-with-a-long-random-token

# Network bind. Default 127.0.0.1 (local only); set 0.0.0.0 to deliberately expose on LAN.
GUBBINS_BRIDGE_HOST=127.0.0.1
GUBBINS_BRIDGE_PORT=8787

# Per-client (per-IP) rate limit — a backstop against runaway query loops. A client may
# burst up to CAPACITY requests, then is held to REFILL requests/second. Defaults shown.
# Set CAPACITY=0 to disable entirely and defer to the LAN/firewall.
GUBBINS_BRIDGE_RATE_CAPACITY=60
GUBBINS_BRIDGE_RATE_REFILL=1

# Optional mDNS / zeroconf advertising so Home Assistant can auto-discover the bridge
# instead of you typing its host/port. Off by default; it carries NO secret (the bearer
# token is never advertised — you still enter it in HA). It is only meaningful when the
# bridge is LAN-exposed (GUBBINS_BRIDGE_HOST=0.0.0.0); on the loopback default it is
# auto-skipped. Set to "on" to enable.
GUBBINS_BRIDGE_MDNS=off
# Optional service instance name shown in a discovery browser (default "Gubbins Bridge").
# GUBBINS_BRIDGE_MDNS_NAME=Gubbins Bridge

# Optional LIMITED WRITES. The bridge is strictly read-only by default. Set to "on" to enable
# the POST stock-adjust endpoints (check-in / check-out, quantity adjust). Each write is applied
# through the app's OWN mutation and written back into the synced gubbins-sync.json, so the PWA
# merges it conflict-free on its next sync — never a bespoke database write. Leave OFF unless you
# specifically want an automation / voice command to change stock. Same bearer token + rate limit.
GUBBINS_BRIDGE_ALLOW_WRITES=off

# Optional SNAPSHOT PUSH ("push to bridge"). For a user who does NOT use FS-Access sync (no shared
# folder), the PWA can POST its whole dataset straight to the bridge. Set to "on" to enable
# POST /api/v1/snapshot, which accepts the same versioned backup JSON the bridge reads and replaces
# the snapshot atomically (the watcher then re-hydrates it). Off by default and INDEPENDENT of
# writes above. JSON source only — refused for a raw .sqlite source. Same bearer token + rate limit.
GUBBINS_BRIDGE_ALLOW_PUSH=off
# Optional hard cap (bytes) on a pushed snapshot; default 64 MiB (67108864). Lower it on a
# constrained host (e.g. a Pi/NAS on an SD card). An over-large push is rejected with HTTP 413.
# GUBBINS_BRIDGE_MAX_PUSH_BYTES=67108864
